# Test Chronicle Agent Configuration
# 
# Copy this file to .env.local and fill in the values from your chart dashboard
# 
# Required for all commands:
# CHRONICLE_API_KEY - Your personal API key for authentication
#                     Get this from: https://your-dashboard-url/auth/settings
CHRONICLE_API_KEY=

# Required for sync command:
# CHRONICLE_PROJECT_ID - Unique identifier for your project
#                        Get this by running: test-chronicle-agent init
CHRONICLE_PROJECT_ID=

# Optional - Dashboard URL
# Defaults to http://localhost:3000 if not specified
# Use your dashboard URL. Examples:
#   - http://localhost:3000 (local development)
#   - https://test-chronicle.vercel.app (production)
CHRONICLE_DASHBOARD_URL=

# Optional - Project path
# Defaults to current working directory if not specified
# Use this if running test-chronicle-agent from a different directory
# PROJECT_PATH=./my-project
